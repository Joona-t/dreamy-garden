{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "short_name": "Dreamy Garden",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_title": "Dreamy Garden 🌸",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "dreamy-garden@lovespark",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "is_exempt": true,
        "justification": "This extension does not collect, transmit, or store any user data."
      }
    }
  },
  "default_locale": "en"
}
